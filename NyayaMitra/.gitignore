# NyayaMitra — Root .gitignore

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual env ───────────────────────────────────────
venv/
env/
.venv/
ENV/

# ── Environment variables ─────────────────────────────
.env
.env.local
.env.production
.env.staging
**/secrets.env

# ── ChromaDB vector store ─────────────────────────────
backend/chroma_db/
chroma_db/

# ── Node / Frontend ───────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
.next/
out/

# ── OS ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Logs ─────────────────────────────────────────────
*.log
logs/

# ── Temp / cache ─────────────────────────────────────
.cache/
tmp/
temp/
*.tmp
