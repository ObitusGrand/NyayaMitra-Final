# ═══════════════════════════════════════════════════════════════════
# NyayaMitra Frontend — Environment Variables
# Copy to .env.local for local dev
# Set in Vercel Project Settings → Environment Variables for production
# ═══════════════════════════════════════════════════════════════════

# ── Backend API URL ───────────────────────────────────────────────
# Local development:
VITE_API_URL=http://localhost:8000
# Production (set this in Vercel dashboard → Environment Variables):
# VITE_API_URL=https://nyayamitra-backend.railway.app

# ── App Config ────────────────────────────────────────────────────
VITE_APP_NAME=NyayaMitra
VITE_APP_VERSION=1.0.0

# ── External Links (used in the UI) ──────────────────────────────
VITE_TELEGRAM_BOT=https://t.me/nyayamitra_bot
VITE_NALSA_HELPLINE=15100

