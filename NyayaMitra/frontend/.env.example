# NyayaMitra Frontend Environment Variables
# Copy to .env.local and fill in your Firebase credentials

# Backend API URL
VITE_API_URL=http://localhost:8000

# Firebase Configuration
# Get these from Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# To enable Google Sign-In:
# 1. Go to Firebase Console → Authentication → Sign-in method
# 2. Enable Google provider
# 3. Add your domain to Authorized domains

# To enable GitHub Sign-In:
# 1. Go to Firebase Console → Authentication → Sign-in method 
# 2. Enable GitHub provider
# 3. Create a GitHub OAuth App at https://github.com/settings/developers
# 4. Set the authorization callback URL from Firebase Console
# 5. Enter the Client ID and Client Secret in Firebase Console
