# ═══════════════════════════════════════════════════════════════════
# NyayaMitra — Environment Variables
# Copy this to .env and fill in your actual values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════

# ── LLM / AI (Required for full functionality) ─────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Used for embeddings

# ── Voice Pipeline (Sarvam AI) ─────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Telegram Bot ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# ── Exotel IVR ────────────────────────────────────────────────────
EXOTEL_SID=your_exotel_account_sid
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_PHONE=+911234567890

# ── Backend URL (for IVR + Telegram internal calls) ───────────────
# Set this to your Railway deployment URL in production
# Leave as localhost for local dev
BACKEND_URL=https://nyayamitra-backend.railway.app

# ── Cloudinary (for IVR TTS audio hosting) ────────────────────────
# Free tier: 25GB storage, 25GB bandwidth/month
# Sign up at: https://cloudinary.com/
CLOUDINARY_URL=https://api.cloudinary.com/v1_1/your_cloud_name

# ── Supabase (Optional — for persistent case storage) ──────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# ── ChromaDB (Vector DB) ───────────────────────────────────────────
# Leave empty to use default ./chroma_db directory
CHROMA_PERSIST_DIR=./chroma_db

# ── Allowed Origins (Frontend URLs for CORS) ─────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=*

# ── Misc ──────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
